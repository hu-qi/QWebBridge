{
  "manifest_version": 3,
  "name": "QwebBridge",
  "version": "1.0.0",
  "description": "Browser bridge for AI agents",
  "permissions": [
    "tabs",
    "activeTab",
    "debugger",
    "storage",
    "alarms",
    "tabGroups",
    "windows"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
